{
  "manifest_version": 3,
  "name": "QuickAsset Web Clipper",
  "version": "0.1.0",
  "description": "Save webpage images directly into QuickAsset.",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
