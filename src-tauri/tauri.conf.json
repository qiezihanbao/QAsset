{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "QuickAsset",
  "version": "0.1.2",
  "identifier": "com.quickasset.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "QuickAsset",
        "width": 800,
        "height": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": true,
        "startMenuFolder": "QuickAsset",
        "installerHooks": "nsis/installer-hooks.nsh"
      },
      "wix": {
        "upgradeCode": "c69ee039-6885-501b-a2e7-9ec97827960c",
        "language": [
          "zh-CN",
          "en-US"
        ]
      }
    }
  }
}
